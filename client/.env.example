# Base URL of the Express API. Used server-side by next.config.ts to proxy
# /api/* requests to Express (no NEXT_PUBLIC_ prefix needed — the rewrite
# happens on the Next.js server, not in the browser).
API_URL=http://localhost:5000

# Must match server/.env DEMO_USER_EMAIL / DEMO_USER_PASSWORD. Only used to
# visibly pre-fill the "Demo Login" button on /login — not a real secret,
# safe to expose to the browser.
NEXT_PUBLIC_DEMO_EMAIL=demo@skillpathai.com
NEXT_PUBLIC_DEMO_PASSWORD=DemoPass123!
