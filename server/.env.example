# Port the Express server listens on
PORT=5000

# MongoDB connection string — local mongod or an Atlas free-tier cluster
MONGODB_URI=mongodb://127.0.0.1:27017/skillpath-ai

# The browser-facing origin (the Next.js app). Requests go through Next's
# /api rewrite proxy to this Express server, so this doubles as the CORS
# allow-origin AND Better Auth's baseURL / cookie / OAuth-callback origin.
CLIENT_ORIGIN=http://localhost:3000

# Required. Signs and encrypts sessions/cookies. Generate with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=

# Required feature for this project. Create an OAuth 2.0 Client ID in Google
# Cloud Console (APIs & Services > Credentials) with an authorized redirect
# URI of {CLIENT_ORIGIN}/api/auth/callback/google, e.g.
#   http://localhost:3000/api/auth/callback/google
# Until both are set, the server still starts and email/password auth still
# works — only Google sign-in is disabled (see src/lib/auth.ts).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Seeded demo account (created via `npm run seed:demo`). The "Demo Login"
# button on /login visibly auto-fills these before signing in.
DEMO_USER_EMAIL=demo@skillpathai.com
DEMO_USER_PASSWORD=DemoPass123!

# Stripe test-mode keys (https://dashboard.stripe.com/test/apikeys). Until
# both are set, the server still starts and free enrollment still works —
# only paid checkout and the webhook are disabled (see src/lib/stripe.ts).
# STRIPE_WEBHOOK_SECRET comes from `stripe listen --forward-to
# localhost:5000/api/webhooks/stripe` in local dev, or the endpoint's
# signing secret in the Stripe Dashboard for a deployed webhook.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AI Study Planner (OpenAI, https://platform.openai.com/api-keys). Until
# OPENAI_API_KEY is set, the server still starts and every other feature
# still works — only study-plan generation/refinement is disabled unless
# AI_DEMO_MODE is on (see src/lib/openai.ts). OPENAI_MODEL defaults to
# gpt-4o-mini if unset.
#
# AI_DEMO_MODE defaults to false (see config/env.ts) — leave it false/unset
# in any real deployment so the app uses the real OpenAI integration above.
# Set it to true only for local development/demos, to generate study plans
# deterministically from real MongoDB course data WITHOUT calling OpenAI or
# requiring an API key.
AI_DEMO_MODE=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
